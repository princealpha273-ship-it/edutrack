# PostgreSQL Database (required for Vercel deployment)
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/edutrack"

JWT_SECRET="edutrack-secret-key-change-in-production"
MPESA_CONSUMER_KEY="your-mpesa-consumer-key"
MPESA_CONSUMER_SECRET="your-mpesa-consumer-secret"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="your-mpesa-passkey"
MPESA_CALLBACK_URL="https://your-app.vercel.app/api/mpesa/callback"
MPESA_ENV="sandbox"
